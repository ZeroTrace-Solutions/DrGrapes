{
  "expo": {
    "name": "Dr Grapes",
    "slug": "drgrapes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/dr-grapes-icon.png",
    "scheme": "drgrapes",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121414",
        "foregroundImage": "./assets/images/dr-grapes-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/dr-grapes-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#121414",
          "dark": {
            "backgroundColor": "#121414"
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiUrl": "http://192.168.1.10:3000"
    }
  }
}
